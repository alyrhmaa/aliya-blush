<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Judul -->
        <TextView
            android:text="Kalkulator Bangun"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#C2185B"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- SEGITIGA -->
        <TextView
            android:text="SEGITIGA"
            android:textStyle="bold"
            android:textColor="#D63384"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Input Alas -->
        <EditText
            android:id="@+id/etAlas"
            android:hint="Masukkan Alas"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Input Tinggi -->
        <EditText
            android:id="@+id/etTinggi"
            android:hint="Masukkan Tinggi"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Button -->
        <Button
            android:id="@+id/btnSegitiga"
            android:text="Hitung Luas Segitiga"
            android:backgroundTint="#EC407A"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- KUBUS -->
        <TextView
            android:text="KUBUS"
            android:textStyle="bold"
            android:textColor="#D63384"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Input Sisi -->
        <EditText
            android:id="@+id/etSisi"
            android:hint="Masukkan Sisi"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Button -->
        <Button
            android:id="@+id/btnKubus"
            android:text="Hitung Volume Kubus"
            android:backgroundTint="#F06292"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- HASIL -->
        <TextView
            android:text="HASIL"
            android:textStyle="bold"
            android:textColor="#D63384"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvHasil"
            android:text="Hasil akan muncul di sini"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#880E4F"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>