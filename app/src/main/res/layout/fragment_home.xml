<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF1F5"
    tools:context=".Home.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TOOLBAR -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:background="#EC407A"
            app:title="Bina Desa"
            app:titleTextColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- HEADER -->
        <androidx.cardview.widget.CardView
            android:id="@+id/headerCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#EC407A"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat Datang 👋"
                    android:fontFamily="@font/angkor"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tvDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aplikasi layanan digital desa berbasis Android."
                    android:fontFamily="@font/poppins_boldd"
                    android:textColor="#FFF0F5"
                    android:textSize="15sp"
                    android:layout_marginTop="10dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- MENU -->
        <TextView
            android:id="@+id/tvMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu Utama"
            android:fontFamily="@font/poppins_regularr"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#C2185B"
            android:layout_marginStart="24dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/headerCard"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- BUTTON KALKULATOR -->
        <Button
            android:id="@+id/btnToKalkulator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Kalkulator Bangun"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:backgroundTint="#EC407A"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvMenu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BUTTON CUSTOM 1 -->
        <Button
            android:id="@+id/btnToCustom1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Custom Activity 1"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:backgroundTint="#D81B60"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnToKalkulator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BUTTON CUSTOM 2 -->
        <Button
            android:id="@+id/btnToCustom2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Custom Activity 2"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:backgroundTint="#C2185B"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnToCustom1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BUTTON WEB -->
        <Button
            android:id="@+id/btnToWeb"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Website Desa"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:backgroundTint="#AD1457"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="30dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnToCustom2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
        <!-- BUTTON LOGOUT -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:backgroundTint="#880E4F"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="30dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnToWeb"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>