<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Aliyablush"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- 🔥 LOGIN JADI LAUNCHER -->
        <activity
            android:name=".Home.pertemuan_3.Login_Activity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- REGISTER -->
        <activity
            android:name=".Home.pertemuan_3.Register_Activity"
            android:exported="false" />

        <!-- OTP -->
        <activity
            android:name=".Home.pertemuan_3.Verification_Activity"
            android:exported="false" />

        <!-- DASHBOARD -->
        <activity
            android:name=".Home.pertemuan_4.Dashboard_Activity"
            android:exported="false" />

        <!-- OPTIONAL (biarkan kalau masih dipakai) -->
        <activity
            android:name=".Home.pertemuan_2.MainActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_4.Custom1_Activity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_4.Custom2_Activity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_6.Splash_Activity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_6.WebView_Activity"
            android:exported="false" />

    </application>

</manifest>